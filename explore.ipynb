    "## Funções para ler e salvar imagens"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "da31c149",
   "metadata": {},
   "outputs": [],
   "source": [
    "def show_image(filepath: str, title: str = None, cmap: str = None):\n",
    "    \"\"\"Opens and displays a .png or .tif image.\"\"\"\n",
    "    img = Image.open(filepath)\n",
    "    img_array = np.array(img)\n",
    "\n",
    "    plt.figure(figsize=(8, 8))\n",
    "    plt.imshow(img_array, cmap=cmap)\n",
    "    plt.axis(\"off\")\n",
    "    if title:\n",
    "        plt.title(title)\n",
    "    plt.show()"
   ]
  },

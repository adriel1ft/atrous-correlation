   "metadata": {},
   "outputs": [],
   "source": [
    "def exibir_canais_rgb(r_color, g_color, b_color, rgb_array):\n",
    "    plt.figure(figsize=(12, 4))\n",
    "    plt.subplot(1, 4, 1)\n",
    "    plt.imshow(rgb_array)\n",
    "    plt.title(\"Original\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.subplot(1, 4, 2)\n",
    "    plt.imshow(r_color)\n",
    "    plt.title(\"Canal R\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.subplot(1, 4, 3)\n",
    "    plt.imshow(g_color)\n",
    "    plt.title(\"Canal G\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.subplot(1, 4, 4)\n",
    "    plt.imshow(b_color)\n",
    "    plt.title(\"Canal B\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "f89f2883",
   "metadata": {},
   "outputs": [],
   "source": [
    "def processar_canais_rgb(image):\n",
    "\n",
    "    img = Image.open(image)\n",
    "    rgb_array = np.array(img)\n",
    "\n",
    "    r = rgb_array[:, :, 0]\n",
    "    g = rgb_array[:, :, 1]\n",
    "    b = rgb_array[:, :, 2]\n",
    "\n",
    "    r_color = np.stack([r, np.zeros_like(r), np.zeros_like(r)], axis=2)\n",
    "    g_color = np.stack([np.zeros_like(g), g, np.zeros_like(g)], axis=2)\n",
    "    b_color = np.stack([np.zeros_like(b), np.zeros_like(b), b], axis=2)\n",
    "\n",
    "    return r_color, g_color, b_color, rgb_array\n"
   ]
  },
